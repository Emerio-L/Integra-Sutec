# ============================================
# Integra Sutec — Variables de Entorno
# ============================================

# --- Base de Datos ---
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/integra_sutec?retryWrites=true&w=majority

# --- JWT ---
JWT_SECRET=tu_secreto_jwt_aqui_cambiar_en_produccion
JWT_REFRESH_SECRET=tu_secreto_refresh_aqui_cambiar_en_produccion
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- API ---
API_PORT=4000
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# --- Sitio Público ---
PUBLIC_API_URL=http://localhost:4000/api

# --- Admin ---
VITE_API_URL=http://localhost:4000/api
