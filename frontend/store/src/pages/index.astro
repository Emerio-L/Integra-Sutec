---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';
---
<BaseLayout title="Integra Sutec — Tecnología que impulsa tu día">
  <section class="hero" id="hero">
    <div class="hero-circuit" aria-hidden="true"></div>
    <div class="hero-inner">
      <h1>Tecnología que<br/><span>impulsa tu día</span></h1>
      <div class="hero-media" id="hero-media" aria-label="Productos destacados del banner"><div class="hero-orbit"></div><span>IS</span></div>
    </div>
  </section>

  <section class="category-rail-wrap" aria-label="Categorías destacadas">
    <div class="category-rail" id="category-rail">
      <a class="all-categories" href="/catalogo"><span class="grid-icon">⊞</span><strong>Todas las<br/>categorías</strong><b>›</b></a>
      <div class="category-loading">Cargando categorías…</div>
    </div>
  </section>

  <section class="featured-section">
    <div class="section-heading"><h2>Productos destacados</h2><a href="/catalogo">Ver todos →</a></div>
    <div id="featured-products" class="featured-grid" aria-live="polite">
      {Array.from({length:6}).map(() => <div class="product-card skeleton-card"><div></div><span></span><span></span><b></b></div>)}
    </div>
    <div id="home-error" class="home-error" hidden>No fue posible cargar el catálogo. <a href="/catalogo">Intentar desde productos</a>.</div>
  </section>

  <section class="benefit-bar" aria-label="Beneficios">
    <div><span>◆</span><p><strong>Compra segura</strong><small>Tus datos protegidos siempre</small></p></div>
    <div><span>▰</span><p><strong>Envío rápido</strong><small>A toda Guatemala</small></p></div>
    <div><span>♢</span><p><strong>Garantía local</strong><small>Respaldo y servicio en GT</small></p></div>
    <div><span>◉</span><p><strong>Soporte experto</strong><small>Te ayudamos a elegir</small></p></div>
  </section>

  <script define:vars={{ API }}>
    const categoryColors = ['blue','mint','violet','orange'];
    const categorySymbols = ['⌚','▦','◇','▣'];
    const money = new Intl.NumberFormat('es-GT',{style:'currency',currency:'GTQ',minimumFractionDigits:2});
    const escapeHtml = (value='') => String(value).replace(/[&<>'"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));
    const imageUrl = (path) => path ? (path.startsWith('http') ? path : API + path) : '';
    function renderCategories(items) {
      const rail = document.getElementById('category-rail'); if (!rail) return;
      const first = rail.querySelector('.all-categories')?.outerHTML || '';
      rail.innerHTML = first + items.slice(0,4).map((cat,i) => `<a class="category-item" href="/catalogo?category=${encodeURIComponent(cat._id)}"><span class="category-icon ${categoryColors[i]}">${categorySymbols[i]}</span><p><strong>${escapeHtml(cat.name)}</strong><small>${escapeHtml(cat.description || 'Tecnología para todos')}</small><em>Ver productos →</em></p></a>`).join('');
      const footer = document.getElementById('footer-categories'); if (footer) footer.innerHTML = items.slice(0,4).map(cat => `<a href="/catalogo?category=${encodeURIComponent(cat._id)}">${escapeHtml(cat.name)}</a>`).join('');
    }
    function renderProducts(items) {
      const grid = document.getElementById('featured-products'); if (!grid) return;
      if (!items.length) { grid.innerHTML = '<p class="empty-products">No hay productos destacados disponibles.</p>'; return; }
      grid.innerHTML = items.slice(0,6).map((p,i) => { const img=imageUrl(p.images?.[0]); const desc=escapeHtml(p.description || p.category_id?.name || 'Producto tecnológico'); return `<article class="product-card"><button class="favorite-btn" data-favorite="${p._id}" aria-label="Agregar ${escapeHtml(p.name)} a favoritos">♡</button>${i<2?'<span class="new-badge">NUEVO</span>':''}<a class="product-image" href="/catalogo">${img?`<img src="${escapeHtml(img)}" alt="${escapeHtml(p.name)}" loading="lazy"/>`:'<span>IS</span>'}</a><h3>${escapeHtml(p.name)}</h3><p>${desc}</p><div class="product-bottom"><strong>${money.format(Number(p.unit_price || 0))}</strong><button class="quick-cart" data-product="${p._id}" aria-label="Ver producto en catálogo">🛒</button></div></article>`; }).join('');
      grid.querySelectorAll('[data-product]').forEach(btn => btn.addEventListener('click',()=>location.assign('/catalogo')));
      wireFavorites();
    }
    function renderHeroProducts(items) {
      const media = document.getElementById('hero-media');
      const images = items.map(item => ({ src:imageUrl(item.images?.[0]), name:item.name })).filter(item => item.src).slice(0,3);
      if (!media || !images.length) return;
      media.innerHTML = `<div class="hero-product-stage">${images.map((item,index) => `<img class="hero-product hero-product-${index+1}" src="${escapeHtml(item.src)}" alt="${escapeHtml(item.name)}"/>`).join('')}</div>`;
    }
    function wireFavorites() { const key='integrasutec:favorites:v1'; let saved=[]; try { saved=JSON.parse(localStorage.getItem(key)||'[]'); } catch {} document.querySelectorAll('[data-favorite]').forEach(btn=>{ const id=btn.dataset.favorite; const sync=()=>{btn.textContent=saved.includes(id)?'♥':'♡';btn.classList.toggle('active',saved.includes(id));}; sync(); btn.addEventListener('click',()=>{saved=saved.includes(id)?saved.filter(x=>x!==id):[...saved,id];try{localStorage.setItem(key,JSON.stringify(saved));}catch{}sync();}); }); }
    async function loadHome() { try { const [catsRes,productsRes] = await Promise.all([fetch(`${API}/api/categories`),fetch(`${API}/api/products?limit=6&status=active`)]); if(!catsRes.ok||!productsRes.ok) throw new Error(); const [cats,products]=await Promise.all([catsRes.json(),productsRes.json()]); renderCategories(cats.data||[]); renderProducts(products.data||[]); let bannerLoaded=false; try { const bannerRes=await fetch(`${API}/api/v1/public/banners`); if(bannerRes.ok){const data=await bannerRes.json();const banner=(data.data||[])[0];const url=banner?.desktopImageUrl||banner?.desktop_image_url;if(url){const media=document.getElementById('hero-media');media.innerHTML=`<img src="${escapeHtml(url)}" alt=""/>`;bannerLoaded=true;}} } catch {} if(!bannerLoaded) renderHeroProducts(products.data||[]); } catch { document.getElementById('featured-products').innerHTML=''; document.getElementById('home-error').hidden=false; const rail=document.getElementById('category-rail'); rail.querySelector('.category-loading')?.remove(); } }
    loadHome();
  </script>
</BaseLayout>
