---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="Solicitar Cotización — Integra Sutec" description="Solicita una cotización personalizada para suministros tecnológicos empresariales.">
  <section class="bg-gradient-to-br from-dark-950 via-primary-950 to-dark-950 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-display text-3xl md:text-4xl font-bold text-white mb-3 animate-slide-up">
        Solicitar <span class="gradient-text">Cotización</span>
      </h1>
      <p class="text-dark-300 text-lg">Completa el formulario y recibirás una propuesta formal en menos de 24 horas.</p>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
    <div id="success-msg" class="hidden bg-green-50 border border-green-200 rounded-2xl p-6 flex items-start gap-4">
      <div class="text-3xl">✅</div>
      <div>
        <h3 class="font-bold text-green-800 text-lg mb-1">¡Solicitud enviada exitosamente!</h3>
        <p class="text-green-700 text-sm">Un asesor de Integra Sutec te contactará en menos de <strong>24 horas hábiles</strong> al correo o teléfono que proporcionaste.</p>
      </div>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="card p-8 md:p-10">
      <div class="flex items-center gap-3 mb-8 pb-6 border-b border-dark-100">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <div>
          <h2 class="font-display text-xl font-bold text-dark-900">Datos para Cotización</h2>
          <p class="text-sm text-dark-400">Todos los campos marcados con * son obligatorios.</p>
        </div>
      </div>

      <form id="quote-form" class="space-y-6">
        <!-- Company Info -->
        <div>
          <h3 class="text-sm font-semibold text-dark-800 uppercase tracking-wider mb-4">Información de la Empresa</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="q-company" class="text-sm font-medium text-dark-700 block mb-1.5">Empresa *</label>
              <input type="text" id="q-company" required class="input-field" placeholder="Nombre de la empresa" />
            </div>
            <div>
              <label for="q-nit" class="text-sm font-medium text-dark-700 block mb-1.5">NIT *</label>
              <input type="text" id="q-nit" required class="input-field" placeholder="1234567-8" />
            </div>
          </div>
        </div>

        <!-- Contact Person -->
        <div>
          <h3 class="text-sm font-semibold text-dark-800 uppercase tracking-wider mb-4">Persona de Contacto</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="q-name" class="text-sm font-medium text-dark-700 block mb-1.5">Nombre *</label>
              <input type="text" id="q-name" required class="input-field" placeholder="Tu nombre completo" />
            </div>
            <div>
              <label for="q-position" class="text-sm font-medium text-dark-700 block mb-1.5">Cargo</label>
              <input type="text" id="q-position" class="input-field" placeholder="Gerente de TI, etc." />
            </div>
            <div>
              <label for="q-email" class="text-sm font-medium text-dark-700 block mb-1.5">Email *</label>
              <input type="email" id="q-email" required class="input-field" placeholder="correo@empresa.com" />
            </div>
            <div>
              <label for="q-phone" class="text-sm font-medium text-dark-700 block mb-1.5">Teléfono *</label>
              <input type="tel" id="q-phone" required class="input-field" placeholder="+502 0000-0000" />
            </div>
          </div>
        </div>

        <!-- Products -->
        <div>
          <h3 class="text-sm font-semibold text-dark-800 uppercase tracking-wider mb-4">Productos de Interés</h3>
          <div class="space-y-4">
            <div>
              <label for="q-category" class="text-sm font-medium text-dark-700 block mb-1.5">Categoría de interés</label>
              <select id="q-category" class="input-field">
                <option value="">Selecciona una categoría</option>
                <option value="computadoras">Computadoras y Laptops</option>
                <option value="redes">Redes y Conectividad</option>
                <option value="impresoras">Impresoras y Escáneres</option>
                <option value="almacenamiento">Almacenamiento</option>
                <option value="accesorios">Accesorios</option>
                <option value="software">Software y Licencias</option>
                <option value="servidores">Servidores</option>
                <option value="seguridad">Seguridad</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div>
              <label for="q-details" class="text-sm font-medium text-dark-700 block mb-1.5">Detalle de productos y cantidades *</label>
              <textarea id="q-details" rows="5" required class="input-field resize-none" placeholder="Ej: 10 laptops HP ProBook 450 G10, 5 switches Cisco SG350-28, etc."></textarea>
            </div>
            <div>
              <label for="q-deadline" class="text-sm font-medium text-dark-700 block mb-1.5">Fecha de entrega esperada</label>
              <input type="date" id="q-deadline" class="input-field" />
            </div>
          </div>
        </div>

        <!-- Notes -->
        <div>
          <label for="q-notes" class="text-sm font-medium text-dark-700 block mb-1.5">Notas adicionales</label>
          <textarea id="q-notes" rows="3" class="input-field resize-none" placeholder="Requisitos especiales, condiciones de pago, etc."></textarea>
        </div>

        <div class="pt-4 border-t border-dark-100 flex flex-col sm:flex-row gap-4">
          <button type="submit" class="btn-primary flex-1 sm:flex-none">
            Enviar Solicitud de Cotización
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </button>
          <p class="text-xs text-dark-400 self-center">Recibirás una respuesta en máximo 24 horas hábiles.</p>
        </div>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById('quote-form') as HTMLFormElement;
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
    const API = 'http://localhost:4000/api';

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const original = submitBtn.textContent;
      submitBtn.textContent = 'Enviando...';
      submitBtn.disabled = true;

      const data = {
        company:  (document.getElementById('q-company') as HTMLInputElement).value,
        nit:      (document.getElementById('q-nit') as HTMLInputElement).value,
        name:     (document.getElementById('q-name') as HTMLInputElement).value,
        position: (document.getElementById('q-position') as HTMLInputElement).value,
        email:    (document.getElementById('q-email') as HTMLInputElement).value,
        phone:    (document.getElementById('q-phone') as HTMLInputElement).value,
        category: (document.getElementById('q-category') as HTMLSelectElement).value,
        details:  (document.getElementById('q-details') as HTMLTextAreaElement).value,
        deadline: (document.getElementById('q-deadline') as HTMLInputElement).value,
        notes:    (document.getElementById('q-notes') as HTMLTextAreaElement).value,
      };

      try {
        const res = await fetch(`${API}/quote-requests/public`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json();

        if (res.ok) {
          // Show success message
          const successMsg = document.getElementById('success-msg');
          if (successMsg) successMsg.classList.remove('hidden');
          form.reset();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        } else {
          alert(json.error || 'Error al enviar. Inténtalo de nuevo.');
        }
      } catch (err) {
        alert('Error de conexión. Verifica tu internet e inténtalo de nuevo.');
      } finally {
        submitBtn.textContent = original;
        submitBtn.disabled = false;
      }
    });
  </script>
</BaseLayout>
