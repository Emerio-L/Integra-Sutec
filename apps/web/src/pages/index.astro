---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const categories = [
  { name: 'Computadoras', icon: '💻', desc: 'Laptops y desktops empresariales', count: '20+' },
  { name: 'Redes', icon: '🌐', desc: 'Switches, routers y access points', count: '15+' },
  { name: 'Impresoras', icon: '🖨️', desc: 'Impresoras y multifuncionales', count: '12+' },
  { name: 'Almacenamiento', icon: '💾', desc: 'SSD, HDD y soluciones NAS', count: '18+' },
  { name: 'Accesorios', icon: '🖱️', desc: 'Periféricos y complementos', count: '30+' },
  { name: 'Software', icon: '📀', desc: 'Licencias empresariales', count: '10+' },
  { name: 'Servidores', icon: '🖥️', desc: 'Servidores y componentes', count: '8+' },
  { name: 'Seguridad', icon: '🔒', desc: 'UPS, cámaras y protección', count: '14+' },
];

const brands = ['HP', 'Dell', 'Lenovo', 'Cisco', 'Epson', 'TP-Link', 'Microsoft', 'Logitech', 'APC', 'Western Digital'];

const stats = [
  { value: '500+', label: 'Productos disponibles' },
  { value: '200+', label: 'Clientes corporativos' },
  { value: '10+', label: 'Años de experiencia' },
  { value: '99.9%', label: 'Disponibilidad del sistema' },
];
---

<BaseLayout title="Integra Sutec — Suministros Tecnológicos Empresariales en Guatemala">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-dark-950 via-primary-950 to-dark-950 min-h-[90vh] flex items-center">
    <!-- Decorative elements -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-20 left-10 w-72 h-72 bg-primary-600/20 rounded-full blur-3xl animate-float"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent-500/15 rounded-full blur-3xl animate-float" style="animation-delay: 3s;"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary-500/5 rounded-full blur-3xl"></div>
      <!-- Grid pattern -->
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.02)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary-500/10 border border-primary-500/20 text-primary-300 text-sm mb-8 animate-fade-in">
          <span class="w-2 h-2 rounded-full bg-accent-400 animate-pulse"></span>
          Suministros tecnológicos en Guatemala
        </div>

        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6 animate-slide-up">
          Tecnología que impulsa
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-primary-400 via-accent-400 to-primary-300">
            tu empresa
          </span>
        </h1>

        <p class="text-lg sm:text-xl text-dark-300 leading-relaxed mb-10 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">
          Somos tu socio estratégico en suministros tecnológicos. Desde computadoras empresariales
          hasta infraestructura de redes, equipamos tu negocio con las mejores marcas.
        </p>

        <div class="flex flex-wrap gap-4 animate-slide-up" style="animation-delay: 0.3s;">
          <a href="/catalogo" class="btn-primary text-base px-8 py-4">
            Ver Catálogo
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="/cotizacion" class="btn-secondary !text-white !border-white/20 hover:!bg-white/10 text-base px-8 py-4">
            Solicitar Cotización
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="relative -mt-12 z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="card-glass grid grid-cols-2 md:grid-cols-4 gap-6 p-8">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="font-display text-3xl font-bold gradient-text">{stat.value}</div>
          <div class="text-sm text-dark-500 mt-1">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Categories -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="text-center mb-14">
      <h2 class="section-title mb-4">Nuestras <span class="gradient-text">Categorías</span></h2>
      <p class="section-subtitle mx-auto">Todo lo que tu empresa necesita en tecnología, organizado para ti.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {categories.map((cat) => (
        <a href="/catalogo" class="card group p-6 hover:border-primary-200 hover:-translate-y-1">
          <div class="text-3xl mb-3">{cat.icon}</div>
          <h3 class="font-semibold text-dark-900 mb-1 group-hover:text-primary-600 transition-colors">{cat.name}</h3>
          <p class="text-sm text-dark-400 mb-3">{cat.desc}</p>
          <span class="text-xs font-medium text-primary-600 bg-primary-50 px-2.5 py-1 rounded-full">{cat.count} productos</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Why Us -->
  <section class="bg-dark-50/50 py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="section-title mb-4">¿Por qué <span class="gradient-text">Integra Sutec</span>?</h2>
        <p class="section-subtitle mx-auto">Más que un proveedor, somos tu aliado tecnológico.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card p-8 text-center hover:-translate-y-1">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary-500 to-primary-700 flex items-center justify-center mx-auto mb-5 shadow-lg shadow-primary-500/25">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="font-semibold text-lg text-dark-900 mb-3">Productos Garantizados</h3>
          <p class="text-dark-500 text-sm leading-relaxed">Trabajamos solo con marcas líderes y productos con garantía oficial para proteger tu inversión.</p>
        </div>

        <div class="card p-8 text-center hover:-translate-y-1">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-accent-500 to-accent-700 flex items-center justify-center mx-auto mb-5 shadow-lg shadow-accent-500/25">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="font-semibold text-lg text-dark-900 mb-3">Entrega Rápida</h3>
          <p class="text-dark-500 text-sm leading-relaxed">Stock disponible en Guatemala con despacho inmediato para mantener tu operación en marcha.</p>
        </div>

        <div class="card p-8 text-center hover:-translate-y-1">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center mx-auto mb-5 shadow-lg shadow-primary-500/25">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <h3 class="font-semibold text-lg text-dark-900 mb-3">Soporte Dedicado</h3>
          <p class="text-dark-500 text-sm leading-relaxed">Equipo de asesores expertos para ayudarte a elegir la solución perfecta para tus necesidades.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Brands -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="text-center mb-12">
      <h2 class="section-title mb-4">Marcas <span class="gradient-text">que respaldamos</span></h2>
      <p class="section-subtitle mx-auto">Trabajamos con los fabricantes más reconocidos del mercado.</p>
    </div>

    <div class="flex flex-wrap justify-center gap-8 items-center">
      {brands.map((brand) => (
        <div class="px-6 py-4 rounded-xl bg-dark-50 text-dark-600 font-semibold text-lg hover:bg-primary-50 hover:text-primary-700 transition-all duration-300 cursor-default">
          {brand}
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-r from-primary-600 via-primary-700 to-primary-800 py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-6">
        ¿Listo para equipar tu empresa?
      </h2>
      <p class="text-primary-100 text-lg mb-10 max-w-2xl mx-auto">
        Solicita una cotización personalizada y recibe la mejor propuesta para tus necesidades tecnológicas.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/cotizacion" class="btn-accent text-base px-8 py-4">
          Solicitar Cotización Ahora
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="/contacto" class="inline-flex items-center px-8 py-4 text-white font-semibold border-2 border-white/30 rounded-xl hover:bg-white/10 transition-all duration-300">
          Contactar Ventas
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
